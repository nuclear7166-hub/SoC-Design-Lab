#include <stdio.h>
#include "platform.h"
#include "xil_printf.h"
#include "xparameters.h"
#include "xgpio.h"
#include "sleep.h"

// 1. 하드코딩 대신 xparameters.h에 정의된 매크로를 직접 사용하는 것이 실무 표준입니다.
#define AXI_SERVO_BASEADDR  XPAR_AXI_SERVO_K_V1_0_0_BASEADDR

// 2. BASEADDR가 아닌 DEVICE_ID 매크로를 정확히 사용해야 GPIO가 초기화됩니다.
#define GPIO_SW_DEVICE_ID   XPAR_GPIO_0_DEVICE_ID
#define SW_CHANNEL1         1

XGpio GPIO_SW;

int main()
{
    init_platform();

    // 3. GPIO 초기화 및 상태 검증
    int status = XGpio_Initialize(&GPIO_SW, GPIO_SW_DEVICE_ID);
    if (status != XST_SUCCESS) {
        xil_printf("GPIO Initialization Failed!\n\r");
        return XST_FAILURE;
    }

    xil_printf("Servo Motor Control System Started...\n\r");

    // 4. 무한 루프 시작
    while(1)
    {
        // GPIO로부터 스위치 값을 읽어옴 (매번 호출 함수를 쓰지 않고 변수에 담는 것이 효율적)
        u32 sw_data = XGpio_DiscreteRead(&GPIO_SW, SW_CHANNEL1);

        // 비트 마스킹 (1<<0, 1<<1, 1<<2, 1<<3) 정상화
        if (sw_data & (1 << 0)) {
            Xil_Out32(AXI_SERVO_BASEADDR, 0);
        }
        else if (sw_data & (1 << 1)) {
            Xil_Out32(AXI_SERVO_BASEADDR, 7);
        }
        else if (sw_data & (1 << 2)) {
            Xil_Out32(AXI_SERVO_BASEADDR, 16);
        }
        else if (sw_data & (1 << 3)) {
            Xil_Out32(AXI_SERVO_BASEADDR, 25); // 또는 SG90 스펙에 맞춰 26 사용
        }

        // 5. AXI 버스 과부하를 막기 위한 아주 짧은 딜레이
        usleep(10000);
    }

    // 6. cleanup_platform은 프로그램이 완전히 끝날 때(실제론 도달하지 않음) 위치해야 합니다.
    cleanup_platform();
    return 0;
}
