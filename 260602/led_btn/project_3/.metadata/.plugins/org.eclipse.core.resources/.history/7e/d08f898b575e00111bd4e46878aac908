/*
 * helloworld.c: simple test application
 *
 * This application configures UART 16550 to baud rate 9600.
 * PS7 UART (Zynq) is not initialized by this application, since
 * bootrom/bsp configures it to baud rate 115200
 *
 * ------------------------------------------------
 * | UART TYPE   BAUD RATE                        |
 * ------------------------------------------------
 *   uartns550   9600
 *   uartlite    Configurable only in HW design
 *   ps7_uart    115200 (configured by bootrom/bsp)
 */

#include <stdio.h>
#include "platform.h"
#include "xil_printf.h"
#include "xgpio.h"
#include "xparameters.h"

#define CHANNEL_1   1
#define CHANNEL_2   2

#define BTN_UP  0
#define BTN_LEFT    1
#define BTN_RIGHT   2
#define BTN_DOWN    3

XGpio GPIO_LED;
XGpio GPIO_BTN;
int main()
{
    init_platform();

    XGpio_Initialize(&GPIO_LED, XPAR_AXI_GPIO_0_DEVICE_ID);
    XGpio_Initialize(&GPIO_BTN, XPAR_AXI_GPIO_1_DEVICE_ID);
    //XGpio_SetDataDirection(&GPIO_LED, CHANNEL_1, 0x0000000e);
    XGpio_SetDataDirection(&GPIO_LED, CHANNEL_1, 0x00000000);
    XGpio_SetDataDirection(&GPIO_BTN, CHANNEL_1, 0x0000000f);

while (1)
{
    if(XGpio_DiscreteRead(&GPIO_BTN, CHANNEL_1) & (1<<BTN_UP) ){ // 0x0001&1 <<0
                    XGpio_DiscreteWrite(&GPIO_LED, CHANNEL_1, 0x000f);
                    usleep(500000); // 500ms delay
                    XGpio_DiscreteWrite(&GPIO_LED, CHANNEL_1, 0x0000);
                    usleep(500000); // 500ms delay
                    print("Hello World\n\r");
                    print("BTN_Position : BTN_UP");
                    cleanup_platform();
}
}
else if(XGpio_DiscreteRead(&GPIO_BTN, CHANNEL_1) & (1<<BTN_LEFT) ){ // 0x0001&1 <<1
                    XGpio_DiscreteWrite(&GPIO_LED, CHANNEL_1, 0x00f0);
                    usleep(500000); // 500ms delay
                    XGpio_DiscreteWrite(&GPIO_LED, CHANNEL_1, 0x0000);
                    usleep(500000); // 500ms delay
                    print("Hello World\n\r");
                    print("BTN_Position : BTN_LEFT");
                    cleanup_platform();
}
else if(XGpio_DiscreteRead(&GPIO_BTN, CHANNEL_1) & (1<<BTN_RIGHT) ){ // 0x0001&1 <<2
                    XGpio_DiscreteWrite(&GPIO_LED, CHANNEL_1, 0x0f00);
                    usleep(500000); // 500ms delay
                    XGpio_DiscreteWrite(&GPIO_LED, CHANNEL_1, 0x0000);
                    usleep(500000); // 500ms delay
                    print("Hello World\n\r");
                    print("BTN_Position : BTN_RIGHT");
                    cleanup_platform();
}
}
else if(XGpio_DiscreteRead(&GPIO_BTN, CHANNEL_1) & (1<<BTN_DOWN) ){ // 0x0001&1 <<3
                    XGpio_DiscreteWrite(&GPIO_LED, CHANNEL_1, 0xf000);
                    usleep(500000); // 500ms delay
                    XGpio_DiscreteWrite(&GPIO_LED, CHANNEL_1, 0x0000);
                    usleep(500000); // 500ms delay
                    print("Hello World\n\r");
                    print("BTN_Position : BTN_DOWN");
                    cleanup_platform();
}
}
}
