/*
 * helloworld.c: simple test application
 *
 * This application configures UART 16550 to baud rate 9600.
 * PS7 UART (Zynq) is not initialized by this application, since
 * bootrom/bsp configures it to baud rate 115200
 *
 * ------------------------------------------------
 * | UART TYPE   BAUD RATE                        |
 * ------------------------------------------------
 *   uartns550   9600
 *   uartlite    Configurable only in HW design
 *   ps7_uart    115200 (configured by bootrom/bsp)
 */

#include <stdio.h>
#include "platform.h"
#include "xil_printf.h"
#include "xparameters.h"
#include "sleep.h"
#include "xil_io.h"

#define AXI_LCD_BASEADDR 0x00010000
#define LCD_SEC AXI_LCD_BASEADDR + 0x00
#define LCD_MIN AXI_LCD_BASEADDR + 0x04
#define LCD_HOUR AXI_LCD_BASEADDR + 0x08

#define AXI_RTC_BASEADDR 0x00008000
#define AXI_RTC_DIGIT1 AXI_RTC_BASEADDR + 0x00
#define AXI_RTC_DIGIT2 AXI_RTC_BASEADDR + 0x04
#define AXI_RTC_DIGIT3 AXI_RTC_BASEADDR + 0x08
#define AXI_RTC_DIGIT4 AXI_RTC_BASEADDR + 0x0c

int main()
{
    init_platform();

    print("Hello World\n\r");
    print("LCD Display test \n\r");
    	u8 SEC = 0;
    	u8 MIN = 0;
    	u8 HOUR = 0;

    while(1)
    {
    	SEC = Xil_In32(AXI_RTC_DIGIT2);
    	MIN = Xil_In32(AXI_RTC_DIGIT3);
    	HOUR = Xil_In32(AXI_RTC_DIGIT4);

    	Xil_Out32(LCD_SEC, SEC);
    	Xil_Out32(LCD_MIN, MIN);
    	Xil_Out32(LCD_HOUR, HOUR);
    }
    cleanup_platform();
    return 0;
}
